# ── Server ports ──────────────────────────────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=3000

# URL the frontend uses to reach the backend (must be publicly reachable in prod)
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# ── Storage paths ─────────────────────────────────────────────────────────────
DATA_DIR=./backend/data
UPLOAD_DIR=./backend/data/uploads
SQLITE_PATH=./backend/data/app.db
VECTOR_STORE_DIR=./backend/data/vectorstore

# ── Embedding model ───────────────────────────────────────────────────────────
LATTICE_EMBEDDER=sentence_transformers  # or 'openrouter' or 'hash'
EMBEDDING_MODEL=Alibaba-NLP/gte-Qwen2-1.5B-instruct
EMBEDDING_MODEL_FALLBACK=BAAI/bge-m3
LATTICE_EMBED_BATCH_SIZE=16
LATTICE_EMBEDDING_BASE_URL=https://openrouter.ai/api/v1
LATTICE_EMBEDDING_API_KEY=

# OpenRouter free embedding example:
# LATTICE_EMBEDDER=openrouter
# EMBEDDING_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2:free
# LATTICE_EMBEDDING_BASE_URL=https://openrouter.ai/api/v1
# LATTICE_EMBEDDING_API_KEY=sk-or-v1-your-openrouter-key

# ── LLM / inference ───────────────────────────────────────────────────────────
LLM_MODEL=Qwen/Qwen2.5-1.5B-Instruct
LLM_BACKEND=transformers  # or 'llama_cpp' or 'openai_compat'
INFERENCE_DEVICE=auto  # cpu|mps|cuda|auto
LATTICE_LLM_BASE_URL=http://localhost:11434/v1
LATTICE_LLM_API_KEY=
LATTICE_LLM_HTTP_REFERER=
LATTICE_LLM_APP_TITLE=Lattice
LATTICE_LLM_GGUF_PATH=
LATTICE_LLM_N_CTX=4096

# OpenRouter example:
# LLM_BACKEND=openai_compat
# LLM_MODEL=openai/gpt-oss-120b:free
# LATTICE_LLM_BASE_URL=https://openrouter.ai/api/v1
# LATTICE_LLM_API_KEY=sk-or-v1-your-openrouter-key

# ── Upload limits ─────────────────────────────────────────────────────────────
MAX_UPLOAD_MB=200
